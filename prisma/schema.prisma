generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum AccountProvider {
  PHONE
  EMAIL
  WECHAT
  QQ
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  icon      String   @default("")
  tools     Tool[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tools     ToolTag[]
}

model Tool {
  id                   String  @id @default(cuid())
  name                 String
  slug                 String  @unique
  description          String
  content              String  @default("")
  tutorial             String  @default("")
  website              String?
  normalizedWebsite    String?
  sourceUrl            String?
  sourceType           String  @default("import")
  pricing              String  @default("unknown")

  featured             Boolean @default(false)
  featuredOrder        Int     @default(0)

  clicks               Int     @default(0)
  views                Int     @default(0)
  outClicks            Int     @default(0)

  logoUrl              String  @default("")
  screenshots          String  @default("")
  searchText           String  @default("")

  categoryId           String
  categoryConfidence   Int     @default(0)
  tagConfidence        Int     @default(0)
  classificationStatus String  @default("unknown")

  reviewStatus         String  @default("pending")
  contentQualityStatus String  @default("unknown")
  qualityScore         Int     @default(0)
  needsManualReview    Boolean @default(true)
  needsContentRewrite  Boolean @default(false)

  reviewNotes          String    @default("")
  rejectReason         String    @default("")
  reviewedBy           String    @default("")
  reviewedAt           DateTime?
  publishedAt          DateTime?
  importedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  isPublished          Boolean  @default(false)

  category             Category            @relation(fields: [categoryId], references: [id])
  tags                 ToolTag[]
  viewEvents           ToolViewEvent[]
  outClickEvents       ToolOutClickEvent[]

  @@index([categoryId])
  @@index([slug])
  @@index([clicks])
  @@index([views])
  @@index([outClicks])
  @@index([isPublished, reviewStatus])
  @@index([reviewStatus, createdAt])
  @@index([contentQualityStatus, createdAt])
  @@index([classificationStatus, createdAt])
  @@index([qualityScore])
  @@index([categoryId, reviewStatus])
  @@index([featured, featuredOrder])
}

model ToolTag {
  toolId String
  tagId  String

  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tool   Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
}

model User {
  id            String  @id @default(cuid())
  name          String?
  image         String?

  phone         String?   @unique
  phoneVerified Boolean   @default(false)

  email         String?   @unique
  emailVerified DateTime?
  role          UserRole  @default(USER)

  accounts      Account[]
  sessions      Session[]

  reversePromptTasks ReversePromptTask[]
  collections        Collection[]
  orders             Order[]
  aiRecords          AIGenerationRecord[]

  // ==========================================
  // 🔔 消息通知关联 (新增)
  // ==========================================
  notifications      Notification[]

  // ==========================================
  // 💡 商业化与每日额度限制字段
  // ==========================================
  freeUsesToday Int       @default(0) 
  lastUsedDate  DateTime?
  isPro         Boolean   @default(false) 
  bonusCredits  Int       @default(0) 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String          @id @default(cuid())
  userId            String
  provider          AccountProvider
  providerAccountId String

  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhoneVerificationCode {
  id        String    @id @default(cuid())
  phone     String
  code      String
  purpose   String    @default("login")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([phone, purpose, expiresAt])
}

model EmailVerificationCode {
  id        String    @id @default(cuid())
  email     String
  code      String
  purpose   String    @default("login")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@index([email, purpose, expiresAt])
}

model Submission {
  id                String  @id @default(cuid())
  name              String
  website           String
  websiteNormalized String?
  description       String
  category          String
  tags              String  @default("")
  contact           String  @default("")

  content           String  @default("")
  tutorial          String  @default("")

  sourceType        String  @default("submission")
  status            String  @default("pending")
  qualityScore      Int     @default(0)
  needsManualReview Boolean @default(true)

  suggestedCategory String    @default("")
  suggestedTags     String    @default("")
  reviewNotes       String    @default("")
  rejectReason      String    @default("")
  reviewedBy        String    @default("")
  reviewedAt        DateTime?
  convertedToolId   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reason            String   @default("")

  @@index([status, createdAt])
  @@index([websiteNormalized])
  @@index([convertedToolId])
}

model ToolViewEvent {
  id         String   @id @default(cuid())
  toolId     String
  sessionKey String
  dayBucket  String
  createdAt  DateTime @default(now())

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, sessionKey, dayBucket])
  @@index([toolId, createdAt])
  @@index([createdAt])
}

model ToolOutClickEvent {
  id         String   @id @default(cuid())
  toolId     String
  sessionKey String?
  targetUrl  String?
  createdAt  DateTime @default(now())

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, createdAt])
  @@index([createdAt])
}

model ReversePromptTask {
  id                   String    @id @default(cuid())
  userId               String?
  status               String    @default("pending")
  inputType            String    @default("images")
  sourceCount          Int       @default(0)
  inputUrls            String    @default("[]")
  outputLanguage       String    @default("zh")
  outputStyle          String    @default("standard")
  targetPlatform       String    @default("generic")
  model                String    @default("")
  metaJson             String    @default("{}")
  rawResponseText      String    @default("")
  rawResultJson        String    @default("")
  normalizedResultJson String    @default("{}")
  resultJson           String    @default("{}")
  errorMessage         String    @default("")
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([inputType, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  
  title       String   
  description String?  @db.Text
  coverUrl    String?  
  sourceUrl   String   
  platform    String   @default("website") 
  
  tags        String   @default("")
  metaJson    String   @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  outTradeNo    String   @unique 
  amount        Int      
  planType      String   
  status        String   @default("pending") 
  paymentMethod String   @default("wechat")  
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([outTradeNo])
  @@index([createdAt])
}

model AIGenerationRecord {
  id            String   @id @default(cuid())
  userId        String
  toolType      String   
  title         String   @db.Text
  
  originalInput String?  @db.Text 
  resultJson    String?  @db.Text 
  status        String   @default("success") 
  cost          Int      @default(0)
  isFavorited   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([toolType])
}

// ==========================================
// 🔔 消息通知模型 (新增)
// ==========================================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  
  // 消息类型，例如：'system' (系统), 'billing' (资产), 'task' (任务)
  type      String   
  title     String
  content   String   @db.Text
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联到用户，如果用户被删除，通知也会级联删除
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 添加索引以优化查询速度（按用户查未读，按时间排序）
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([userId, createdAt])
}