generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum AccountProvider {
  PHONE
  EMAIL
  WECHAT
  QQ
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  icon      String   @default("")
  tools     Tool[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tools     ToolTag[]
}

model Tool {
  id                   String  @id @default(cuid())
  name                 String
  slug                 String  @unique
  description          String
  content              String  @default("")
  tutorial        String @default("")
  website              String?
  normalizedWebsite    String?
  sourceUrl            String?
  sourceType           String  @default("import")
  pricing              String  @default("unknown")

  featured             Boolean @default(false)
  featuredOrder        Int     @default(0)

  clicks               Int     @default(0)
  views                Int     @default(0)
  outClicks            Int     @default(0)

  logoUrl              String  @default("")
  screenshots          String  @default("")
  searchText           String  @default("")

  categoryId           String
  categoryConfidence   Int     @default(0)
  tagConfidence        Int     @default(0)
  classificationStatus String  @default("unknown")

  reviewStatus         String  @default("pending")
  contentQualityStatus String  @default("unknown")
  qualityScore         Int     @default(0)
  needsManualReview    Boolean @default(true)
  needsContentRewrite  Boolean @default(false)

  reviewNotes          String    @default("")
  rejectReason         String    @default("")
  reviewedBy           String    @default("")
  reviewedAt           DateTime?
  publishedAt          DateTime?
  importedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  isPublished          Boolean  @default(false)

  category             Category            @relation(fields: [categoryId], references: [id])
  tags                 ToolTag[]
  viewEvents           ToolViewEvent[]
  outClickEvents       ToolOutClickEvent[]

  @@index([categoryId])
  @@index([slug])
  @@index([clicks])
  @@index([views])
  @@index([outClicks])
  @@index([isPublished, reviewStatus])
  @@index([reviewStatus, createdAt])
  @@index([contentQualityStatus, createdAt])
  @@index([classificationStatus, createdAt])
  @@index([qualityScore])
  @@index([categoryId, reviewStatus])
  @@index([featured, featuredOrder])
}

model ToolTag {
  toolId String
  tagId  String

  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tool   Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
}

model User {
  id            String  @id @default(cuid())
  name          String?
  image         String?

  phone         String?   @unique
  phoneVerified Boolean   @default(false)

  email         String?   @unique
  emailVerified DateTime?
  role          UserRole  @default(USER)

  accounts      Account[]
  sessions      Session[]

  reversePromptTasks ReversePromptTask[]
  collections        Collection[]
  orders        Order[]

  aiRecords          AIGenerationRecord[]

  // ==========================================
  // 💡 新增：商业化与每日额度限制字段
  // ==========================================
  freeUsesToday Int       @default(0) // 今天已使用的免费次数
  lastUsedDate  DateTime?             // 最后一次扣除次数的日期（用于跨天重置）
  isPro         Boolean   @default(false) // 预留：判断是否为高级/付费用户，高级用户可以无限制或有更高额度

bonusCredits  Int       @default(0) // 用户购买的额外永久积分（如加油包）

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String          @id @default(cuid())
  userId            String
  provider          AccountProvider
  providerAccountId String

  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhoneVerificationCode {
  id        String    @id @default(cuid())
  phone     String
  code      String
  purpose   String    @default("login")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([phone, purpose, expiresAt])
}

model EmailVerificationCode {
  id        String    @id @default(cuid())
  email     String
  code      String
  purpose   String    @default("login")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@index([email, purpose, expiresAt])
}

model Submission {
  id                String  @id @default(cuid())
  name              String
  website           String
  websiteNormalized String?
  description       String
  category          String
  tags              String  @default("")
  contact           String  @default("")

  content           String  @default("")
  tutorial          String  @default("")

  sourceType        String  @default("submission")
  status            String  @default("pending")
  qualityScore      Int     @default(0)
  needsManualReview Boolean @default(true)

  suggestedCategory String    @default("")
  suggestedTags     String    @default("")
  reviewNotes       String    @default("")
  rejectReason      String    @default("")
  reviewedBy        String    @default("")
  reviewedAt        DateTime?
  convertedToolId   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reason            String   @default("")

  @@index([status, createdAt])
  @@index([websiteNormalized])
  @@index([convertedToolId])
}

model ToolViewEvent {
  id         String   @id @default(cuid())
  toolId     String
  sessionKey String
  dayBucket  String
  createdAt  DateTime @default(now())

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, sessionKey, dayBucket])
  @@index([toolId, createdAt])
  @@index([createdAt])
}

model ToolOutClickEvent {
  id         String   @id @default(cuid())
  toolId     String
  sessionKey String?
  targetUrl  String?
  createdAt  DateTime @default(now())

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, createdAt])
  @@index([createdAt])
}

model ReversePromptTask {
  id                   String    @id @default(cuid())
  userId               String?
  status               String    @default("pending")
  inputType            String    @default("images")
  sourceCount          Int       @default(0)
  inputUrls            String    @default("[]")
  outputLanguage       String    @default("zh")
  outputStyle          String    @default("standard")
  targetPlatform       String    @default("generic")
  model                String    @default("")
  metaJson             String    @default("{}")
  rawResponseText      String    @default("")
  rawResultJson        String    @default("")
  normalizedResultJson String    @default("{}")
  resultJson           String    @default("{}")
  errorMessage         String    @default("")
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([inputType, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// 💡 收藏模型：用于存放来自全网（小红书、抖音等）的素材
model Collection {
  id          String   @id @default(cuid())
  userId      String
  
  title       String   // 标题
  description String?  @db.Text
  coverUrl    String?  // 封面图预览
  sourceUrl   String   // 素材原文链接
  platform    String   @default("website") // 来源：xiaohongshu, douyin, website
  
  tags        String   @default("")
  metaJson    String   @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

// ==========================================
// 💡 新增：商业化订单模型
// ==========================================
model Order {
  id            String   @id @default(cuid())
  userId        String
  outTradeNo    String   @unique // 传给微信/支付宝的唯一商户订单号
  amount        Int      // 订单金额（⚠️ 强烈建议单位为“分”，例如 990 代表 9.9 元，避免浮点数精度丢失）
  planType      String   // 套餐类型：例如 "quota_50" (加油包) 或 "monthly_pro" (包月会员)
  status        String   @default("pending") // 支付状态：pending(待支付), paid(已支付), failed(失败), closed(已关闭)
  paymentMethod String   @default("wechat")  // 支付方式：wechat, alipay
  paidAt        DateTime? // 支付成功的时间戳

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([outTradeNo])
  @@index([createdAt])
}

// ==========================================
// 💡 新增：AI 生成通用历史流水表 (Dashboard 专用)
// ==========================================
model AIGenerationRecord {
  id          String   @id @default(cuid())
  userId      String
  
  // 记录属于哪个功能，例如: "reverse", "enhance", "search"
  toolType    String   
  
  // 前端卡片展示的标题/摘要
  title       String   @db.Text
  
originalInput String?  @db.Text // 用户的原始输入短句
  resultJson    String?  @db.Text // AI 生成的完整长句/JSON结果

  // 任务状态: "success", "failed", "pending"
  status      String   @default("success") 
  
  // 这次任务消耗了多少积分
  cost        Int      @default(0)

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([toolType])
}